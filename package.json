{
  "name": "openclaw-memory-pgvector",
  "version": "0.1.0",
  "description": "OpenClaw memory plugin backed by PostgreSQL or YugabyteDB (pgvector) for semantic memory search.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "migrate": "node dist/scripts/migrate-sqlite-to-pgvector.js",
    "migrate:ts": "tsx scripts/migrate-sqlite-to-pgvector.ts",
    "test:pg": "node dist/scripts/test-pg-connection.js",
    "rollback:pg": "node dist/scripts/rollback-pg.js",
    "install:setup": "bash scripts/install.sh"
  },
  "bin": {
    "openclaw-migrate-memory-to-pg": "./dist/scripts/migrate-sqlite-to-pgvector.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openclaw",
    "memory",
    "pgvector",
    "postgresql",
    "yugabyte",
    "migration"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^11.6.0",
    "openai": "^6.25.0",
    "pg": "^8.13.1",
    "pgvector": "^0.2.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "openclaw": {
    "extensions": ["./plugin/index.ts"]
  }
}
